{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/session-start.mjs\"",
            "timeout": 10,
            "statusMessage": "Reconciling Claude Code background jobs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/session-end.mjs\"",
            "timeout": 10,
            "statusMessage": "Pruning completed Claude Code jobs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/review-gate.mjs\"",
            "timeout": 900,
            "statusMessage": "Asking Claude Code to review changes"
          }
        ]
      }
    ]
  }
}
