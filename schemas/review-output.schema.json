{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "next_steps", "coverage", "uncertainty", "budget_exhausted", "recommended_followup"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approve", "needs-attention"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "findings": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "body", "file", "line_start", "line_end", "confidence", "recommendation"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "body": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "file": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "recommendation": { "type": "string", "maxLength": 2000 }
        }
      }
    },
    "next_steps": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files_examined", "files_skipped", "areas"],
      "properties": {
        "files_examined": { "type": "array", "maxItems": 500, "items": { "type": "string", "minLength": 1, "maxLength": 1024 } },
        "files_skipped": { "type": "array", "maxItems": 500, "items": { "type": "string", "minLength": 1, "maxLength": 1024 } },
        "areas": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 500 } }
      }
    },
    "uncertainty": { "type": "string", "enum": ["low", "medium", "high"] },
    "budget_exhausted": { "type": "boolean" },
    "evidence_lease_exhausted": { "type": "boolean" },
    "cost_budget_exhausted": { "type": "boolean" },
    "turn_limit_reached": { "type": "boolean" },
    "recommended_followup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "focus", "reason"],
      "properties": {
        "profile": { "type": "string", "enum": ["none", "quick", "standard", "deep"] },
        "focus": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
        "reason": { "type": "string", "maxLength": 2000 }
      }
    }
  }
}
