{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "coverage", "uncertainty", "budget_exhausted", "recommended_followup"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approve", "needs-attention"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "findings": {
      "type": "array", "maxItems": 40,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["category", "severity", "title", "body", "location", "confidence", "recommendation"],
        "properties": {
          "category": { "type": "string", "enum": ["outcome", "assumption", "feasibility", "completeness", "safety", "verification", "cost", "other"] },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "body": { "type": "string", "minLength": 1, "maxLength": 4000 },
          "location": {
            "type": "object", "additionalProperties": false, "required": ["file"],
            "properties": {
              "file": { "type": "string", "minLength": 1, "maxLength": 1024 },
              "section": { "type": "string", "minLength": 1, "maxLength": 500 },
              "line_start": { "type": "integer", "minimum": 1 },
              "line_end": { "type": "integer", "minimum": 1 }
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "recommendation": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      }
    },
    "coverage": {
      "type": "object", "additionalProperties": false, "required": ["areas_examined", "areas_skipped"],
      "properties": {
        "areas_examined": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
        "areas_skipped": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 500 } }
      }
    },
    "uncertainty": { "type": "string", "enum": ["low", "medium", "high"] },
    "budget_exhausted": { "type": "boolean" },
    "evidence_lease_exhausted": { "type": "boolean" },
    "cost_budget_exhausted": { "type": "boolean" },
    "turn_limit_reached": { "type": "boolean" },
    "recommended_followup": {
      "type": "object", "additionalProperties": false, "required": ["profile", "focus", "reason"],
      "properties": {
        "profile": { "type": "string", "enum": ["none", "quick", "standard", "deep"] },
        "focus": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
        "reason": { "type": "string", "maxLength": 2000 }
      }
    }
  }
}
